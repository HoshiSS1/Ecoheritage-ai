generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String   @db.NVarChar(100)
  email        String   @unique @db.NVarChar(255)
  passwordHash String   @db.NVarChar(255)
  role         String   @default("User") @db.NVarChar(20)
  avatarUrl    String?  @db.NVarChar(500)
  createdAt    DateTime @default(now())
  reviews      Review[]
}

model Heritage {
  id             Int      @id @default(autoincrement())
  name           String   @db.NVarChar(255)
  description    String?  @db.NVarChar(Max)
  latitude       Float?
  longitude      Float?
  category       String?  @db.NVarChar(100)
  imageUrl       String?  @db.NVarChar(500)
  createdAt      DateTime @default(now())
  address        String?  @db.NVarChar(500)
  aqi            Int?
  bestTime       String?  @db.NVarChar(255)
  color          String?  @db.NVarChar(50)
  contact        String?  @db.NVarChar(255)
  folkTip        String?  @db.NVarChar(Max)
  herbs          String?  @db.NVarChar(Max)
  history        String?  @db.NVarChar(Max)
  humidity       Int?
  level          String?  @db.NVarChar(100)
  medicinalPower String?  @db.NVarChar(100)
  rating         Float?
  regulations    String?  @db.NVarChar(Max)
  reviewsCount   Int?     @default(0)
  slugId         String   @unique @db.NVarChar(100)
  status         String?  @db.NVarChar(100)
  remedies       Remedy[]
  reviews        Review[]
}

model Remedy {
  id          Int       @id @default(autoincrement())
  heritageId  Int?
  name        String    @db.NVarChar(255)
  ingredients String?   @db.NVarChar(Max)
  imageUrl    String?   @db.NVarChar(500)
  createdAt   DateTime  @default(now())
  benefits    String?   @db.NVarChar(Max)
  category    String?   @db.NVarChar(100)
  imageEmoji  String?   @db.NVarChar(50)
  keywords    String?   @db.NVarChar(Max)
  slugId      String    @unique @db.NVarChar(100)
  steps       String?   @db.NVarChar(Max)
  usage       String?   @db.NVarChar(Max)
  heritage    Heritage? @relation(fields: [heritageId], references: [id], onDelete: Cascade)
}

model Review {
  id         Int       @id @default(autoincrement())
  userId     Int?
  heritageId Int?
  rating     Int
  comment    String?   @db.NVarChar(Max)
  createdAt  DateTime  @default(now())
  guestName  String?   @db.NVarChar(100)
  heritage   Heritage? @relation(fields: [heritageId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
